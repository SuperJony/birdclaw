# birdclaw local environment — template.
# Copy to `.env` and fill in real values. `.env` is gitignored and never committed.

# OpenAI-compatible API base URL.
# Include the version segment (".../v1"), matching the OpenAI SDK convention.
# Used by inbox scoring (/chat/completions) and digests/research (/responses).
# Leave unset to use the official endpoint: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API key for the endpoint above.
OPENAI_API_KEY=

# Optional model overrides:
# BIRDCLAW_OPENAI_MODEL=gpt-5.2   # inbox scoring (/v1/chat/completions)
# BIRDCLAW_AI_MODEL=gpt-5.2       # today / digest / research (/v1/responses)
